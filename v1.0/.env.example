# ══════════════════════════════════════════════════════════════════════════════
# Supply Chain v1.0 — Environment Variables
# Copy to .env and fill in your values
# ══════════════════════════════════════════════════════════════════════════════

# ── Google Gemini (required for LLM decisions) ────────────────────────────────
GEMINI_API_KEY=

# ── OpenAI (required for embeddings) ──────────────────────────────────────────
OPENAI_API_KEY=

# ── LangSmith (optional, for tracing) ─────────────────────────────────────────
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=supply-chain-v1.0
LANGCHAIN_TRACING_V2=true

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/supply_chain_v1
DB_NAME=supply_chain_v1
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=postgres
DB_PORT=5432

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Gmail SMTP ────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_RECIPIENT=

# ── Finance ───────────────────────────────────────────────────────────────────
MONTHLY_BUDGET=50000
BUDGET_AUTO_APPROVE_PCT=0.30
BUDGET_ESCALATE_PCT=0.70

# ── Pipeline Config ──────────────────────────────────────────────────────────
RESTOCK_THRESHOLD=15
DEADLINE_DAYS=6

# ── Agent URLs (Docker internal) ─────────────────────────────────────────────
MARKET_API_URL=http://market-api:9000
PRICING_AGENT_URL=http://pricing-agent:9001
INVENTORY_AGENT_URL=http://inventory-agent:8000
SUPPLIER_A_URL=http://supplier-a:8011
SUPPLIER_B_URL=http://supplier-b:8012
SUPPLIER_C_URL=http://supplier-c:8013
ORDER_AGENT_URL=http://order-agent:8001
NOTIFICATION_AGENT_URL=http://notification-agent:8002
FINANCE_AGENT_URL=http://finance-agent:8003
API_GATEWAY_URL=http://api-gateway:8080

# ── Gateway ───────────────────────────────────────────────────────────────────
API_KEY=dev-key-12345
